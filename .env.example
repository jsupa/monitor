# Discord webhook URL for notifications (default — can be overridden per monitor)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# LLM API key (DeepSeek by default, OpenAI-compatible)
LLM_API_KEY=sk-...

# LLM base URL (defaults to DeepSeek: https://api.deepseek.com)
# LLM_BASE_URL=https://api.deepseek.com

# LLM model (defaults to deepseek-v4-pro)
# LLM_MODEL=deepseek-v4-pro

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/monitor

# Path to monitor config directory (used by sync:monitors)
MONITORS_DIR=./monitors
